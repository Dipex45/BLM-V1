# App
APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
PORT=3000

# Firebase Admin SDK
# Use one of these for server-side token verification and Firestore writes.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Redis / BullMQ
REDIS_URL=

# AI Support
GEMINI_API_KEY=
GEMINI_MODEL="gemini-1.5-flash"
AI_DAILY_PROMPT_LIMIT=50

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Paystack
VITE_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Email Provider: Resend
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM="BLM Motors <operations@blmmotors.com>"

# SMS Provider: Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google Maps Platform
GOOGLE_MAPS_PLATFORM_KEY=
VITE_GOOGLE_MAPS_PLATFORM_KEY=

# Observability
SENTRY_DSN=
LOG_LEVEL=info
